{
  "name": "financialapp",
  "version": "1.1.4",
  "description": "App desktop local-first de análise financeira",
  "author": "deadport",
  "repository": {
    "type": "git",
    "url": "https://github.com/deadport/FinancialApp.git"
  },
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "build:main": "esbuild src/main/main.ts src/main/preload.ts --bundle --platform=node --external:electron --external:better-sqlite3 --outdir=dist-electron --format=cjs",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac dmg --arm64",
    "dist:mac:x64": "npm run build && electron-builder --mac dmg --x64",
    "dist:mac:private-beta": "bash scripts/build-mac-private-beta.sh",
    "dist:win": "npm run build && electron-builder --win nsis --x64",
    "dist:win:arm64": "npm run build && electron-builder --win nsis --arm64",
    "pack:dir": "npm run build && electron-builder --dir",
    "release:patch": "npm version patch && git push origin HEAD --tags",
    "release:minor": "npm version minor && git push origin HEAD --tags",
    "release:major": "npm version major && git push origin HEAD --tags",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "start": "electron ."
  },
  "build": {
    "appId": "com.deadport.financialapp",
    "productName": "FinancialApp",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "assets/**",
      "package.json",
      "node_modules/**"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.finance"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "deadport",
        "repo": "FinancialApp"
      }
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.24.0",
    "sharp": "^0.35.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "electron-updater": "^6.3.9",
    "exceljs": "^4.4.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  }
}
